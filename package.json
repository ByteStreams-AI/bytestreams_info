    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
