# ============================================
# ByteStreams Intranet — Environment Config
# Copy to .env and fill in your values
# ============================================

# --- Cloudflare Access ---
CF_ACCESS_TEAM_DOMAIN=bytestreams.cloudflareaccess.com
CF_ACCESS_AUD=                # Application Audience (AUD) tag from CF Access

# --- App ---
PUBLIC_BASE_URL=https://bytestreams.info

# --- Development Mock Auth ---
# Set these to bypass CF Access JWT validation in dev mode
DEV_USER_EMAIL=dev@bytestreams.ai
DEV_USER_FIRST_NAME=Dev
DEV_USER_LAST_NAME=User
