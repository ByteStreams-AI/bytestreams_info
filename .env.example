# ============================================
# ByteStreams Intranet — Environment Config
# ============================================

# --- App ---
PUBLIC_BASE_URL=https://bytestreams.info

# --- Supabase ---
# Anon (public) key — safe to use in the browser. RLS enforces access control.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>
# Service role key — server-side only, never sent to browser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>
