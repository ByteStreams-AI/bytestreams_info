{
  "name": "bytestreams-intranet-sso",
  "version": "1.0.0",
  "description": "ByteStreams LLC Intranet — SAML SSO with Google Workspace IdP",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate-certs": "openssl req -x509 -newkey rsa:2048 -keyout certs/sp-key.pem -out certs/sp-cert.pem -days 3650 -nodes -subj '/CN=bytestreams.info'"
  },
  "dependencies": {
    "@node-saml/passport-saml": "^5.0.0",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
